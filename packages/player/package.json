{
  "name": "@shiftcut/player",
  "version": "0.1.0",
  "description": "Embeddable web component for ShiftCut compositions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vadagon/shiftcut",
    "directory": "packages/player"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/shiftcut-player.js",
  "types": "./dist/shiftcut-player.d.ts",
  "exports": {
    ".": {
      "types": "./dist/shiftcut-player.d.ts",
      "script": "./dist/shiftcut-player.global.js",
      "import": "./dist/shiftcut-player.js",
      "require": "./dist/shiftcut-player.cjs"
    },
    "./slideshow": {
      "types": "./dist/slideshow/shiftcut-slideshow.d.ts",
      "script": "./dist/slideshow/shiftcut-slideshow.global.js",
      "import": "./dist/slideshow/shiftcut-slideshow.js",
      "require": "./dist/slideshow/shiftcut-slideshow.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/verify-runtime-pin.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/perf/tsconfig.json",
    "test": "vitest run",
    "perf": "bun run tests/perf/index.ts"
  },
  "dependencies": {
    "@shiftcut/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "gsap": "^3.12.5",
    "puppeteer-core": "^25.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
